{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DazPilot",
  "identifier": "com.dazpilot.app",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DazPilot",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/llama/*", "resources/models/*", "resources/DazPilotBridge.dll", "resources/libDazPilotBridge.dylib", "resources/libDazPilotBridge.so"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE4NzI5MTJBQjQ0RkNFNUMKUldSY3prKzBLcEZ5R0UzTU50VGwwbWVzVHpCT3ZVczhzUjRZdzNFc0ZTa3B2ckt1bmxxNXB3RmkK",
      "endpoints": [
        "https://github.com/millsydotdev/DazPilot/releases/latest/download/latest.json"
      ]
    }
  }
}
