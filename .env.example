# DazPilot Environment Configuration

# Enable mock bridge for development without Daz Studio
# DAZPILOT_DEV_MOCK_BRIDGE=1

# Enable mock AI responses for offline development
# DAZPILOT_DEV_MOCK_AI=1

# AI backend: "local" (llama.cpp) or "ollama"
# DAZPILOT_AI_BACKEND=local

# Path to Daz Studio C++ SDK headers
# DAZ_SDK_PATH=./thirdparty/DAZStudio4.5+ SDK/include
